# Backend
DATABASE_URL=postgresql+asyncpg://sfafms:password@postgres:5432/sfafms
REDIS_URL=redis://redis:6379/0
SECRET_KEY=your-secret-key-here-change-in-production-min-32-chars
REFRESH_SECRET_KEY=your-refresh-key-change-in-production-min-32-chars
